{
  "name": "@lmnr-ai/lmnr",
  "version": "0.8.37",
  "description": "TypeScript SDK for Laminar AI",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": {
        "require": "./dist/index.d.cts",
        "import": "./dist/index.d.mts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./temporal-workflow-interceptors": {
      "types": {
        "require": "./dist/opentelemetry-lib/instrumentation/temporal/workflow-interceptors.d.cts",
        "import": "./dist/opentelemetry-lib/instrumentation/temporal/workflow-interceptors.d.mts"
      },
      "import": "./dist/opentelemetry-lib/instrumentation/temporal/workflow-interceptors.mjs",
      "require": "./dist/opentelemetry-lib/instrumentation/temporal/workflow-interceptors.cjs"
    }
  },
  "types": "dist/index.d.cts",
  "scripts": {
    "prepare": "tsdown",
    "build": "tsdown",
    "test": "tsx --test test/*.test.ts test/**/*.test.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "lmnr": "./dist/cli.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lmnr-ai/lmnr-ts.git"
  },
  "keywords": [
    "laminar",
    "lmnr",
    "sdk",
    "lmnr.ai"
  ],
  "author": "founders@lmnr.ai",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/lmnr-ai/lmnr-ts/issues"
  },
  "homepage": "https://github.com/lmnr-ai/lmnr-ts#README",
