    "@temporalio/workflow": "^1.20.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.0",
    "ai": "^7.0.16",
    "ai-v5": "npm:ai@ai-v5",
    "ai-v6": "npm:ai@ai-v6",
