{
  "description": "Cross-language parity vectors for DebugConfig (build_debug_config / buildDebugConfig). 'env' is the process environment subset; 'expect' is null when debug mode is off, otherwise the expected config fields. 'replay_enabled' asserts the derived property. In debug-replay v2 the cache window is ALWAYS a span id: 'cache_until_span_id' is the hyphen-stripped lowercase hex needle parsed from a span-id-shaped LMNR_DEBUG_CACHE_UNTIL (null when absent or not span-id shaped). The count form was removed.",
  "cases": [
    {
      "name": "debug-off-absent",
      "env": {},
      "expect": null
    },
    {
      "name": "debug-off-false",
      "env": { "LMNR_DEBUG": "false" },
      "expect": null
    },
    {
      "name": "debug-off-zero",
      "env": { "LMNR_DEBUG": "0" },
      "expect": null
    },
    {
      "name": "debug-off-garbage",
      "env": { "LMNR_DEBUG": "maybe" },
      "expect": null
    },
    {
      "name": "debug-on-true",
      "env": { "LMNR_DEBUG": "true", "LMNR_DEBUG_SESSION_ID": "sess-1" },
      "expect": {
        "session_id": "sess-1",
        "replay_trace_id": null,
        "cache_until_span_id": null,
        "replay_enabled": false
      }
    },
    {
      "name": "debug-on-mixed-case",
      "env": { "LMNR_DEBUG": "TRUE", "LMNR_DEBUG_SESSION_ID": "sess-2" },
      "expect": {
        "session_id": "sess-2",
        "replay_trace_id": null,
        "cache_until_span_id": null,
        "replay_enabled": false
      }
    },
    {
      "name": "debug-on-yes",
      "env": { "LMNR_DEBUG": "yes", "LMNR_DEBUG_SESSION_ID": "sess-3" },
      "expect": {
        "session_id": "sess-3",
        "replay_trace_id": null,
        "cache_until_span_id": null,
        "replay_enabled": false
      }
    },
    {
      "name": "debug-on-on",
      "env": { "LMNR_DEBUG": "on", "LMNR_DEBUG_SESSION_ID": "sess-4" },
      "expect": {
        "session_id": "sess-4",
        "replay_trace_id": null,
        "cache_until_span_id": null,
        "replay_enabled": false
      }
    },
    {
      "name": "replay-trace-set-but-no-cache-until",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-6",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "22222222-2222-2222-2222-222222222222"
      },
      "expect": {
        "session_id": "sess-6",
        "replay_trace_id": "22222222-2222-2222-2222-222222222222",
        "cache_until_span_id": null,
        "replay_enabled": false
      }
    },
    {
      "name": "cache-until-non-hex-ignored",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-9",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "44444444-4444-4444-4444-444444444444",
        "LMNR_DEBUG_CACHE_UNTIL": "lots"
      },
      "expect": {
        "session_id": "sess-9",
        "replay_trace_id": "44444444-4444-4444-4444-444444444444",
        "cache_until_span_id": null,
        "replay_enabled": false
      }
    },
    {
      "name": "cache-until-full-uuid-span-id",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-10",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "55555555-5555-5555-5555-555555555555",
        "LMNR_DEBUG_CACHE_UNTIL": "00000000-0000-0000-0123-456789abcdef"
      },
      "expect": {
        "session_id": "sess-10",
        "replay_trace_id": "55555555-5555-5555-5555-555555555555",
        "cache_until_span_id": "00000000000000000123456789abcdef",
        "replay_enabled": true
      }
    },
    {
      "name": "cache-until-full-uuid-span-id-no-hyphen",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-10",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "55555555-5555-5555-5555-555555555555",
        "LMNR_DEBUG_CACHE_UNTIL": "00000000000000000123456789abcdef"
      },
      "expect": {
        "session_id": "sess-10",
        "replay_trace_id": "55555555-5555-5555-5555-555555555555",
        "cache_until_span_id": "00000000000000000123456789abcdef",
        "replay_enabled": true
      }
    },
    {
      "name": "cache-until-last-groups-span-id",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-11",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "55555555-5555-5555-5555-555555555555",
        "LMNR_DEBUG_CACHE_UNTIL": "0123-456789abcdef"
      },
      "expect": {
        "session_id": "sess-11",
        "replay_trace_id": "55555555-5555-5555-5555-555555555555",
        "cache_until_span_id": "0123456789abcdef",
        "replay_enabled": true
      }
    },
    {
      "name": "cache-until-raw-otel-span-id",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-12",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "55555555-5555-5555-5555-555555555555",
        "LMNR_DEBUG_CACHE_UNTIL": "0123456789ABCDEF"
      },
      "expect": {
        "session_id": "sess-12",
        "replay_trace_id": "55555555-5555-5555-5555-555555555555",
        "cache_until_span_id": "0123456789abcdef",
        "replay_enabled": true
      }
    },
    {
      "name": "cache-until-short-hex-suffix-span-id",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-13",
        "LMNR_DEBUG_REPLAY_TRACE_ID": "55555555-5555-5555-5555-555555555555",
        "LMNR_DEBUG_CACHE_UNTIL": "abcdef"
      },
      "expect": {
        "session_id": "sess-13",
        "replay_trace_id": "55555555-5555-5555-5555-555555555555",
        "cache_until_span_id": "abcdef",
        "replay_enabled": true
      }
    },
    {
      "name": "cache-until-span-id-without-replay-trace",
      "env": {
        "LMNR_DEBUG": "1",
        "LMNR_DEBUG_SESSION_ID": "sess-14",
        "LMNR_DEBUG_CACHE_UNTIL": "0123-456789abcdef"
      },
      "expect": {
        "session_id": "sess-14",
        "replay_trace_id": null,
        "cache_until_span_id": "0123456789abcdef",
        "replay_enabled": false
      }
    }
  ]
}
